{
  "expo": {
    "name": "StaffSync",
    "slug": "55staffsync",
    "version": "1.0.0",
    "scheme": "staffsync-scheme",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.daythreedigital.faith"
    },
    "android": {
      "package": "com.daythreedigital.faith",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icon.png",
        "backgroundImage": "./assets/icon.png",
        "monochromeImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f868f392-c1b6-4764-8eb4-3fd04a2294c0"
      }
    },
    "owner": "muhddaimann"
  }
}
